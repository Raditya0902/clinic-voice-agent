# Clinic Voice Agent — Environment Variables

# LLM (Groq — free tier)
GROQ_API_KEY=your_groq_api_key

# Speech to Text (Deepgram)
DEEPGRAM_API_KEY=your_deepgram_api_key

# Text to Speech (ElevenLabs)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=ErXwobaYiN019PkySvjV

# Telephony (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+17075930902

# Tunnel — set to your ngrok hostname only (no https://, no trailing slash)
# Example: abc123.ngrok-free.app
PUBLIC_HOST=
NGROK_URL=your_ngrok_url  # legacy alias kept for reference

# Barge-in: patient can interrupt agent speech after Deepgram finalizes a new utterance
BARGE_IN=0
BARGE_IN_RMS_THRESHOLD=900
BARGE_IN_SPEECH_FRAMES=4
BARGE_IN_SILENCE_FRAMES=2

# Slack (optional — for escalation notifications)
SLACK_WEBHOOK_URL=

# Database
DB_PATH=./clinic.db

# RAG
CHROMA_PERSIST_DIR=./rag/chroma_db
FAQ_RETRIEVAL_MODE=markdown  # markdown for clean demos, chroma for vector retrieval

# LLM Config
LLM_MODEL=llama-3.3-70b-versatile
MAX_RETRIES=3
SLOT_LOCK_TIMEOUT=60
